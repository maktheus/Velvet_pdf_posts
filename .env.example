# ─── Banco de dados ───────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/patadeveludo
DB_USER=postgres
DB_PASS=troque_aqui

# ─── JWT ──────────────────────────────────────────────────
# Mínimo 32 caracteres, gerado aleatoriamente
JWT_SECRET=troque_por_uma_string_aleatoria_longa_aqui

# ─── Mercado Pago ─────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000
MP_PUBLIC_KEY=APP_USR-00000000-0000-0000-0000-000000000000
MP_WEBHOOK_SECRET=seu_webhook_secret

# ─── Frontend ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_MP_PUBLIC_KEY=${MP_PUBLIC_KEY}

# ─── Admin frontend ───────────────────────────────────────
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8080/api/admin

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
